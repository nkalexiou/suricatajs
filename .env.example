# Database
# SQLite (default, no extra services needed):
DATABASE_URL=sqlite:///./db/surikatajs.db
# PostgreSQL (used by docker-compose):
# DATABASE_URL=postgresql://suricatajs:your_password@localhost:5432/suricatajs

# Web UI auth — REQUIRED in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE_MINUTES=480

# Scanner / API key auth (comma-separated for multiple keys)
API_KEYS=your-secret-key-here

# How often to rescan targets (minutes), unless a per-target interval is set
SCAN_INTERVAL_MINUTES=60

# Docker Compose
POSTGRES_PASSWORD=change_me
API_PORT=8085

# Standalone scanner mode: once | scheduled
SCAN_MODE=once
