# Database
# SQLite (default, no extra services needed):
DATABASE_URL=sqlite:///./db/surikatajs.db
# PostgreSQL (used by docker-compose):
# DATABASE_URL=postgresql://suricatajs:suricatajs@localhost:5432/suricatajs

# API Authentication (comma-separated for multiple keys)
API_KEYS=your-secret-key-here

# Docker Compose
POSTGRES_PASSWORD=suricatajs
API_PORT=8085

# Scanner
SCAN_MODE=oneshot
